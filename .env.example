# Realtime Trains next-generation API from https://api-portal.rtt.io
RTT_AUTH_MODE=token
RTT_API_BASE_URL=https://data.rtt.io
RTT_ACCESS_TOKEN=

# Optional legacy Realtime Trains pull API support.
# Use only if your account is on the old api.rtt.io Basic Auth service.
RTT_LEGACY_BASE_URL=https://api.rtt.io/api/v1
RTT_BASIC_USERNAME=
RTT_BASIC_PASSWORD=

# TfL Unified API from https://api-portal.tfl.gov.uk
# TfL currently asks callers to append app_key. app_id is no longer required.
TFL_APP_KEY=

# First-run / demo mode. When no RTT credentials are present, train data falls back to mock data.
USE_MOCK_DATA=false

# Client refresh cadence.
NEXT_PUBLIC_REFRESH_INTERVAL_MS=60000
